rules_version = '2';

// Per-user access: each signed-in user can read/write their own groups and words,
// plus read (but not write) groups/words marked shared:true — these are admin-authored
// entries visible to everyone. Only the owner or an admin can update/delete a record;
// only an admin can create a shared:true record.
// Roles (admin/premium/user) live on users/{uid}.role and cannot be self-elevated by the client —
// the first admin must be promoted manually in the Firebase console; after that, admins can
// change other users' roles from the in-app Admin screen.
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() { return request.auth != null; }
    function isOwner(uid) { return isSignedIn() && request.auth.uid == uid; }
    function isAdmin() {
      return isSignedIn()
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    match /users/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(uid) && request.resource.data.role == 'user';
      allow update: if (isOwner(uid) && request.resource.data.role == resource.data.role)
        || (isAdmin() && !isOwner(uid));
      allow delete: if isOwner(uid); // self-service account deletion
    }

    match /usernames/{name} {
      allow get: if true; // needed to check uniqueness before sign-in
      allow list: if false; // no dumping the full username list
      allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
      allow update: if false;
      allow delete: if isSignedIn() && resource.data.uid == request.auth.uid; // frees the name on account deletion
    }

    // list: a query is allowed only when its filters guarantee every result is
    // the caller's own doc or a shared one (admins may query anything)
    match /groups/{groupId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || resource.data.shared == true || isAdmin());
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || resource.data.shared == true || isAdmin());
      allow delete: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow update: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin())
        && (request.resource.data.shared == resource.data.shared || isAdmin());
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid
        && (request.resource.data.shared == false || (request.resource.data.shared == true && isAdmin()));
    }

    match /words/{wordId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || resource.data.shared == true || isAdmin());
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || resource.data.shared == true || isAdmin());
      allow delete: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow update: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin())
        && (request.resource.data.shared == resource.data.shared || isAdmin());
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid
        && (request.resource.data.shared == false || (request.resource.data.shared == true && isAdmin()));
    }

    // AI-квоты: пишет ТОЛЬКО Cloud Function через Admin SDK (обходит правила).
    // Клиент может прочитать свой счётчик (док с id `${uid}_${day}`), но не менять его.
    match /ai_usage/{usageId} {
      allow read: if isSignedIn() && resource.data.uid == request.auth.uid;
      allow write: if false;
    }
  }
}
